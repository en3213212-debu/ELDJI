<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>ELDJI.19 · The Revolution</title>
    <meta name="description" content="ELDJI.19 - Visual artist, street culture, digital empire. Benvenuto nel futuro del lusso underground.">
    <meta name="keywords" content="eldji, eldji.19, gangster, instagram, visual art, luxury streetwear">
    <meta name="author" content="ELDJI.19">
    <!-- Google Fonts Premium -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #0a0a0c;
            overflow-x: hidden;
            color: #fff;
        }

        /* Particelle animazione sfondo */
        #particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Scrollbar elegante */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #0f0f13;
        }
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #d4af37, #ff6b6b);
            border-radius: 10px;
        }

        /* Navbar ultra premium */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.2rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(5, 5, 10, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(212, 175, 55, 0.3);
            transition: all 0.3s ease;
        }
        .logo {
            font-size: 2rem;
            font-weight: 900;
            background: linear-gradient(135deg, #fff, #d4af37, #ff6b6b);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -1px;
            font-family: 'Orbitron', monospace;
        }
        .nav-links {
            display: flex;
            gap: 2.5rem;
            align-items: center;
        }
        .nav-links a {
            color: #eee;
            text-decoration: none;
            font-weight: 500;
            transition: 0.3s;
            position: relative;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(95deg, #d4af37, #ff6b6b);
            transition: 0.3s;
        }
        .nav-links a:hover::after {
            width: 100%;
        }
        .nav-links a:hover {
            color: #d4af37;
        }
        .insta-btn-nav {
            background: linear-gradient(45deg, #f09433, #d62976, #962fbf);
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            font-weight: 700;
        }
        .insta-btn-nav:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(210, 60, 120, 0.5);
        }

        /* Hero Section - Spettacolare */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            z-index: 2;
            padding: 0 5%;
        }
        .hero-content {
            max-width: 800px;
        }
        .glow-text {
            font-size: 1.2rem;
            color: #d4af37;
            letter-spacing: 3px;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }
        .hero h1 {
            font-size: 5.5rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, #ffffff, #d4af37, #ff6b6b);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .hero p {
            font-size: 1.2rem;
            color: #ccc;
            margin-bottom: 2rem;
            max-width: 550px;
        }
        .btn-group-hero {
            display: flex;
            gap: 1.2rem;
            flex-wrap: wrap;
        }
        .btn-primary {
            background: linear-gradient(95deg, #d4af37, #ff6b6b);
            padding: 1rem 2.2rem;
            border-radius: 50px;
            text-decoration: none;
            color: #0a0a0c;
            font-weight: 700;
            transition: 0.3s;
            border: none;
            cursor: pointer;
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4);
        }
        .btn-outline {
            border: 2px solid #d4af37;
            padding: 1rem 2.2rem;
            border-radius: 50px;
            text-decoration: none;
            color: #d4af37;
            font-weight: 700;
            transition: 0.3s;
        }
        .btn-outline:hover {
            background: #d4af37;
            color: #0a0a0c;
        }

        /* Sezione Gallery Stunning */
        .gallery-section {
            padding: 6rem 5%;
            background: linear-gradient(180deg, #0a0a0c 0%, #141416 100%);
            position: relative;
            z-index: 2;
        }
        .section-title {
            text-align: center;
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 3rem;
            font-family: 'Orbitron', monospace;
        }
        .section-title span {
            background: linear-gradient(135deg, #d4af37, #ff6b6b);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }
        .gallery-item {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            cursor: pointer;
            aspect-ratio: 1 / 1;
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }
        .gallery-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            display: flex;
            align-items: flex-end;
            padding: 1.5rem;
            opacity: 0;
            transition: 0.5s;
        }
        .gallery-item:hover .gallery-overlay {
            opacity: 1;
        }
        .gallery-item:hover img {
            transform: scale(1.1);
        }
        .gallery-overlay h3 {
            font-size: 1.3rem;
            color: #d4af37;
        }

        /* Stats Section */
        .stats-section {
            padding: 5rem 5%;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 3rem;
            text-align: center;
            background: #060608;
        }
        .stat-card {
            flex: 1;
            min-width: 200px;
        }
        .stat-number {
            font-size: 3.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, #d4af37, #ff6b6b);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .stat-label {
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* Newsletter / CTA */
        .cta-section {
            padding: 5rem 5%;
            text-align: center;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
        }
        .cta-section h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .email-input {
            display: inline-flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
            justify-content: center;
        }
        .email-input input {
            padding: 1rem 1.5rem;
            border-radius: 50px;
            border: none;
            width: 300px;
            background: #0f0f13;
            color: white;
            border: 1px solid #d4af37;
        }
        .footer {
            padding: 3rem 5%;
            text-align: center;
            background: #020203;
            border-top: 1px solid #d4af3720;
        }
        .social-icons {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 2rem;
        }
        .social-icons a {
            color: #d4af37;
            font-size: 1.8rem;
            transition: 0.3s;
        }
        .social-icons a:hover {
            transform: translateY(-5px);
            color: #ff6b6b;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 3rem; }
            .navbar { padding: 1rem; flex-direction: column; gap: 1rem; }
            .nav-links { gap: 1rem; }
            .section-title { font-size: 2rem; }
        }
    </style>
</head>
<body>

<canvas id="particles"></canvas>

<nav class="navbar">
    <div class="logo">ELDJI.19</div>
    <div class="nav-links">
        <a href="#home">HOME</a>
        <a href="#gallery">GALLERY</a>
        <a href="#stats">STATS</a>
        <a href="#contact" class="insta-btn-nav"><i class="fab fa-instagram"></i> @eldji.19</a>
    </div>
</nav>

<section id="home" class="hero">
    <div class="hero-content" data-aos="fade-up">
        <div class="glow-text">✦ THE DIGITAL EMPIRE ✦</div>
        <h1>ELDJI.19<br>Il futuro è adesso</h1>
        <p>Visual artist, street culture, luxury underground. Benvenuto nell'universo di Eldji, dove ogni foto racconta una storia di potere e stile.</p>
        <div class="btn-group-hero">
            <a href="#gallery" class="btn-primary"><i class="fas fa-crown"></i> Esplora la gallery</a>
            <a href="https://instagram.com/eldji.19" target="_blank" class="btn-outline"><i class="fab fa-instagram"></i> Segui su IG</a>
        </div>
    </div>
</section>

<section id="gallery" class="gallery-section">
    <h2 class="section-title">Il mio <span>Universo Visivo</span></h2>
    <div class="gallery-grid" id="galleryGrid"></div>
</section>

<section id="stats" class="stats-section">
    <div class="stat-card" data-aos="zoom-in">
        <div class="stat-number">28K+</div>
        <div class="stat-label">Followers</div>
    </div>
    <div class="stat-card" data-aos="zoom-in" data-aos-delay="100">
        <div class="stat-number">500+</div>
        <div class="stat-label">Progetti</div>
    </div>
    <div class="stat-card" data-aos="zoom-in" data-aos-delay="200">
        <div class="stat-number">15M+</div>
        <div class="stat-label">Visualizzazioni</div>
    </div>
    <div class="stat-card" data-aos="zoom-in" data-aos-delay="300">
        <div class="stat-number">24/7</div>
        <div class="stat-label">Sempre attivo</div>
    </div>
</section>

<section id="contact" class="cta-section">
    <h2>Entra nella <span style="color:#d4af37;">Famiglia ELDJI</span></h2>
    <p>Iscriviti per contenuti esclusivi e anteprime</p>
    <div class="email-input">
        <input type="email" placeholder="La tua email" id="emailInput">
        <button class="btn-primary" id="subscribeBtn">Iscriviti ora →</button>
    </div>
</section>

<footer class="footer">
    <div class="social-icons">
        <a href="https://instagram.com/eldji.19" target="_blank"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-tiktok"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-youtube"></i></a>
    </div>
    <p>© 2026 ELDJI.19 — Tutti i diritti riservati. Powered by visione e stile.</p>
    <p style="margin-top: 1rem; font-size: 0.8rem;">✨ The revolution is now ✨</p>
</footer>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ duration: 1000, once: true });

    // PARTICOLARE ANIMAZIONE SFONDO
    const canvas = document.getElementById('particles');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    let particlesArray = [];
    const numberOfParticles = 80;
    for(let i = 0; i < numberOfParticles; i++) {
        particlesArray.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            radius: Math.random() * 2 + 1,
            speedX: (Math.random() - 0.5) * 0.5,
            speedY: (Math.random() - 0.5) * 0.3,
            color: `rgba(212, 175, 55, ${Math.random() * 0.4 + 0.2})`
        });
    }
    function animateParticles() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particlesArray.forEach(p => {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
            ctx.fillStyle = p.color;
            ctx.fill();
            p.x += p.speedX;
            p.y += p.speedY;
            if(p.x < 0) p.x = canvas.width;
            if(p.x > canvas.width) p.x = 0;
            if(p.y < 0) p.y = canvas.height;
            if(p.y > canvas.height) p.y = 0;
        });
        requestAnimationFrame(animateParticles);
    }
    animateParticles();
    window.addEventListener('resize', () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    });

    // GALLERY FOTO GANGSTER PREMIUM
    const galleryImages = [
        { title: "THE DON", url: "https://media.istockphoto.com/id/157441824/photo/gangster-boss.jpg?s=612x612&w=0&k=20&c=PEN89zyp8pKqO2qJ8t5c1D7WqK4N6RmEqYjZF2y1UZo=" },
        { title: "GOLDEN CHAIN", url: "https://media.istockphoto.com/id/1276468325/photo/portrait-of-a-young-gangster-with-gold-chain.jpg?s=612x612&w=0&k=20&c=K3EoASAmNdh4fLybO3oWv9kE2jLsXHl1VcUJqVxQhIM=" },
        { title: "SCARFACE VIBES", url: "https://media.istockphoto.com/id/1329856540/photo/mafia-boss-standing-in-the-rain-with-a-suit-and-a-gun-in-his-hand.jpg?s=612x612&w=0&k=20&c=0mClgR7xV-BOzNsPmsNRlAqIX45lsE6-P5QjNcjcfS8=" },
        { title: "STREET SOLDIER", url: "https://media.istockphoto.com/id/1190750998/photo/young-roadman.jpg?s=612x612&w=0&k=20&c=UgwLtCbo5F9RZP_zKW0ZAhqHC_QGuxdOEDB4YdLMohM=" },
        { title: "MAFIA MEETING", url: "https://media.istockphoto.com/id/1272476214/photo/group-of-mafia-gangsters.jpg?s=612x612&w=0&k=20&c=Ivk8YdPxrY1fy6-fxNnA3u7hjmnQ8I-ndT_wAy22-Zo=" },
        { title: "MONEY TALKS", url: "https://media.istockphoto.com/id/184934103/photo/crime-scene-do-not-cross.jpg?s=612x612&w=0&k=20&c=2lL4kK6mN8oP0qR2sT4uV6wX8yZ0aB2cD4eF6gH8iJ=" },
        { title: "KINGPIN", url: "https://media.istockphoto.com/id/1312746520/photo/mafia-boss-posing.jpg?s=612x612&w=0&k=20&c=EZD1JX2BSBfZg5mU5xp0yHfPEjNcSnAak1SgGKU5VLY=" },
        { title: "ELDJI STYLE", url: "https://media.istockphoto.com/id/1295388528/photo/mafia-boss-with-gold-chain.jpg?s=612x612&w=0&k=20&c=8qLXn2XkE7c0lBwS0hKq0N7c9ZjA2kL6nR2kL8mN4=" }
    ];

    const galleryGrid = document.getElementById('galleryGrid');
    galleryImages.forEach(img => {
        const item = document.createElement('div');
        item.className = 'gallery-item';
        item.innerHTML = `
            <img src="${img.url}" alt="${img.title}" loading="lazy">
            <div class="gallery-overlay">
                <h3>✦ ${img.title} ✦</h3>
            </div>
        `;
        item.addEventListener('click', () => {
            window.open('https://instagram.com/eldji.19', '_blank');
        });
        galleryGrid.appendChild(item);
    });

    // Newsletter
    document.getElementById('subscribeBtn').addEventListener('click', () => {
        const email = document.getElementById('emailInput').value;
        if(email) {
            alert(`Grazie ${email}! Benvenuto nella famiglia ELDJI.19`);
            document.getElementById('emailInput').value = '';
        } else {
            alert('Inserisci la tua email per entrare nel club.');
        }
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const target = document.querySelector(this.getAttribute('href'));
            if(target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth' });
            }
        });
    });
</script>
</body>
</html>
